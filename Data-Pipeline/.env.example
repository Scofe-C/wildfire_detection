# =============================================================================
# Wildfire MLOps Pipeline - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# =============================================================================

# NASA FIRMS API key (get one free at https://firms.modaps.eosdis.nasa.gov/api/)
FIRMS_MAP_KEY=your_firms_api_key_here

# Google Cloud Storage bucket name for DVC and data storage
GCS_BUCKET_NAME=wildfire-mlops-dev

# Path to GCP service account key JSON file (for local development)
GCP_KEY_PATH=./gcp-key.json

# Optional: Slack webhook URL for anomaly alerts
SLACK_WEBHOOK_URL=

# Optional: Email recipients for pipeline failure alerts (comma-separated)
ALERT_EMAIL_RECIPIENTS=
