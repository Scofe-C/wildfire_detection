# =============================================================================
# Wildfire MLOps Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git (.gitignore already excludes it).
#
# All team members need:
#   1. FIRMS_MAP_KEY       — NASA fire data API key
#   2. GCS_BUCKET_NAME     — GCP storage bucket
#   3. GCP_KEY_PATH        — path to your service account JSON
#
# For GCP watchdog deployment (Zhengxin runs cloud/deploy.sh once):
#   4. GOOGLE_CLOUD_PROJECT
#   5. GCP_REGION
#   Watchdog variables below are written automatically by deploy.sh
# =============================================================================

# ---------------------------------------------------------------------------
# Core pipeline variables (required for all team members)
# ---------------------------------------------------------------------------

# NASA FIRMS API key — get one free at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=your_firms_api_key_here

# Google Cloud Storage bucket name for DVC and data storage
# Ask Zhengxin for the shared team bucket name
GCS_BUCKET_NAME=wildfire-mlops-dev

# Path to GCP service account key JSON file (for local development)
# Ask Zhengxin for the gcp-key.json file — do NOT commit it
GCP_KEY_PATH=./gcp-key.json

# ---------------------------------------------------------------------------
# Alert configuration (optional but recommended)
# ---------------------------------------------------------------------------

# Slack webhook URL for anomaly and emergency alerts
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Email recipients for pipeline failure alerts (comma-separated)
ALERT_EMAIL_RECIPIENTS=

# ---------------------------------------------------------------------------
# GCP deployment variables (set by cloud/deploy.sh — do not edit manually)
# ---------------------------------------------------------------------------

# GCP project ID — find at https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP region for Cloud Function and Cloud Scheduler
# Must match the region where your GCS bucket lives
GCP_REGION=us-central1

# GCS prefix where Cloud Function writes fire trigger files
# Airflow watchdog_sensor_dag polls this prefix every 2 minutes
# Set automatically by cloud/deploy.sh — do not change manually
WATCHDOG_TRIGGER_PREFIX=watchdog/triggers/

# ---------------------------------------------------------------------------
# Advanced / optional
# ---------------------------------------------------------------------------

# Override the Airflow Fernet key (leave blank for auto-generated)
AIRFLOW__CORE__FERNET_KEY=

# Set to 'true' to enable Airflow example DAGs (useful for debugging)
AIRFLOW__CORE__LOAD_EXAMPLES=false
