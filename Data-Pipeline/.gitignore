# =============================================================================
# Wildfire MLOps Pipeline — .gitignore
# =============================================================================
# Rule of thumb:
#   Code, configs, and DVC pointer files (.dvc) → Git
#   Data blobs, model weights, secrets          → DVC / .env (never Git)
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets & credentials — NEVER commit these
# ---------------------------------------------------------------------------
.env
gcp-key.json
*.pem
*.p12
service_account*.json

# ---------------------------------------------------------------------------
# Data directories — tracked by DVC, not Git
# Commit the corresponding .dvc pointer files and dvc.lock instead.
# ---------------------------------------------------------------------------
/data/raw/
/data/processed/
/data/static/
/models/

# ---------------------------------------------------------------------------
# DVC internal state — managed by DVC, not committed directly
# ---------------------------------------------------------------------------
/tmp/
.dvc/cache/
.dvc/tmp/

# ---------------------------------------------------------------------------
# Python artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
.conda/

# ---------------------------------------------------------------------------
# Airflow runtime state
# ---------------------------------------------------------------------------
airflow.db
airflow.cfg
logs/
/airflow/

# ---------------------------------------------------------------------------
# OS / editor artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# Temporary test outputs
# ---------------------------------------------------------------------------
/tmp_test_*/